//--------------------Types et Config----------------------------

enum Mode : uint8_t { MODE_STANDARD, MODE_CONFIGURATION, MODE_ECONOMIQUE, MODE_MAINTENANCE, MODE_OFF };
enum TypeErreur : uint8_t { ERR_RTC, ERR_GPS, ERR_CAPTEUR, ERR_INCOHERENTE, ERR_SD_PLEINE, ERR_SD, ERR_AUCUNE };

struct Config {
  uint16_t magic;
  uint8_t LOG_INTERVALL;
  uint16_t FILE_MAX_SIZE;
  uint8_t TIMEOUT;
  uint8_t LUMIN;
  uint16_t LUMIN_LOW;
  uint16_t LUMIN_HIGH;
  uint8_t TEMP_AIR;
  int8_t MIN_TEMP_AIR;
  int8_t MAX_TEMP_AIR;
  uint8_t HYGR;
  int8_t HYGR_MINT;
  int8_t HYGR_MAXT;
  uint8_t PRESSURE;
  uint16_t PRESSURE_MIN;
  uint16_t PRESSURE_MAX;
};

const uint16_t CONFIG_MAGIC = 0xBEEF;
const int EEPROM_ADDR = 0;
const Config defaultConfig PROGMEM = { CONFIG_MAGIC, 3, 4096, 1, 1, 255, 768, 1, -10, 60, 1, 0, 50, 1, 850, 1080, };

const char p0[] PROGMEM = "LOG_INTERVALL"; const char p1[] PROGMEM = "FILE_MAX_SIZE";
const char p2[] PROGMEM = "TIMEOUT";       const char p3[] PROGMEM = "LUMIN";
const char p4[] PROGMEM = "LUMIN_LOW";     const char p5[] PROGMEM = "LUMIN_HIGH";
const char p6[] PROGMEM = "TEMP_AIR";      const char p7[] PROGMEM = "MIN_TEMP_AIR";
const char p8[] PROGMEM = "MAX_TEMP_AIR";  const char p9[] PROGMEM = "HYGR";
const char p10[] PROGMEM = "HYGR_MINT";    const char p11[] PROGMEM = "HYGR_MAXT";
const char p12[] PROGMEM = "PRESSURE";     const char p13[] PROGMEM = "PRESSURE_MIN";
const char p14[] PROGMEM = "PRESSURE_MAX";

const char* const paramNames[] PROGMEM = { p0, p1, p2, p3, p4, p5, p6, p7, p8, p9, p10, p11, p12, p13, p14, };

struct ParamDef { uint8_t offset; int16_t minVal; int16_t maxVal; };
const ParamDef paramTable[] PROGMEM = {
  {offsetof(Config, LOG_INTERVALL), 1, 1440}, {offsetof(Config, FILE_MAX_SIZE), 128, 32767},
  {offsetof(Config, TIMEOUT), 1, 3600},       {offsetof(Config, LUMIN), 0, 1},
  {offsetof(Config, LUMIN_LOW), 0, 1023},     {offsetof(Config, LUMIN_HIGH), 0, 1023},
  {offsetof(Config, TEMP_AIR), 0, 1},         {offsetof(Config, MIN_TEMP_AIR), -40, 85},
  {offsetof(Config, MAX_TEMP_AIR), -40, 85},  {offsetof(Config, HYGR), 0, 1},
  {offsetof(Config, HYGR_MINT), -40, 85},     {offsetof(Config, HYGR_MAXT), -40, 85},
  {offsetof(Config, PRESSURE), 0, 1},         {offsetof(Config, PRESSURE_MIN), 300, 1100},
  {offsetof(Config, PRESSURE_MAX), 300, 1100}
};

const uint8_t paramCount = sizeof(paramTable) / sizeof(paramTable[0]);

